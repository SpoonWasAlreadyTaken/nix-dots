<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>name</key>
    <string>Spoon</string>

    <key>settings</key>
    <array>

        <!-- Global -->
        <dict>
            <key>settings</key>
            <dict>
                <key>background</key>
                <string>#040405</string>
                <key>foreground</key>
                <string>#ffffff</string>
                <key>caret</key>
                <string>#beb7ff</string>
                <key>selection</key>
                <string>#424242</string>
                <key>lineHighlight</key>
                <string>#0d0d0f</string>
            </dict>
        </dict>


        <!-- Comments -->
        <dict>
            <key>scope</key>
            <string>comment</string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#424242</string>
                <key>fontStyle</key>
                <string>italic</string>
            </dict>
        </dict>


        <!-- Strings -->
        <dict>
            <key>scope</key>
            <string>
                string,
                constant.character.escape
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#ffe770</string>
            </dict>
        </dict>


        <!-- Numbers -->
        <dict>
            <key>scope</key>
            <string>
                constant.numeric,
                constant.language.boolean
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#f1cfff</string>
            </dict>
        </dict>


        <!-- Null / enum -->
        <dict>
            <key>scope</key>
            <string>
                constant.language.null,
                constant.language.enum
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#6f009c</string>
            </dict>
        </dict>


        <!-- Functions -->
        <dict>
            <key>scope</key>
            <string>
                entity.name.function,
                support.function
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#c3a3ff</string>
            </dict>
        </dict>


        <!-- Function calls -->
        <dict>
            <key>scope</key>
            <string>
                meta.function-call,
                variable.function
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#938bb4</string>
            </dict>
        </dict>


        <!-- Variables -->
        <dict>
            <key>scope</key>
            <string>
                variable,
                variable.other
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#ffb5fd</string>
            </dict>
        </dict>


        <!-- Types / operators -->
        <dict>
            <key>scope</key>
            <string>
                keyword.operator,
                storage.type
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#a769ff</string>
            </dict>
        </dict>


        <!-- Structs/classes -->
        <dict>
            <key>scope</key>
            <string>
                entity.name.type,
                entity.name.class,
                entity.name.struct
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#5abf9f</string>
            </dict>
        </dict>


        <!-- Namespace / modules -->
        <dict>
            <key>scope</key>
            <string>
                entity.name.namespace,
                support.type
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#00c7a2</string>
            </dict>
        </dict>


        <!-- Constants -->
        <dict>
            <key>scope</key>
            <string>
                constant,
                variable.other.constant
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#beb7ff</string>
            </dict>
        </dict>


        <!-- Conditionals -->
        <dict>
            <key>scope</key>
            <string>
                keyword.control,
                keyword.control.conditional
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#ff005d</string>
            </dict>
        </dict>


        <!-- Include/import -->
        <dict>
            <key>scope</key>
            <string>
                keyword.control.import,
                keyword.other.import
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#b568d4</string>
            </dict>
        </dict>


        <!-- Brackets / punctuation -->
        <dict>
            <key>scope</key>
            <string>
                punctuation,
                meta.brace
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#ff7c36</string>
            </dict>
        </dict>


        <!-- Operators -->
        <dict>
            <key>scope</key>
            <string>
                keyword.operator,
                punctuation.separator
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#a769ff</string>
            </dict>
        </dict>


        <!-- Markdown headings etc -->
        <dict>
            <key>scope</key>
            <string>
                markup.heading,
                markup.bold
            </string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#beb7ff</string>
            </dict>
        </dict>

    </array>

    <key>uuid</key>
    <string>spoon</string>
</dict>
</plist>
